PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL connection string for the helpdesk database.
# Adjust user / password / host as needed for your local Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/helpdesk?schema=public"

# Better Auth — secret must be 32+ chars. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET="replace-me-with-a-32-char-secret"
BETTER_AUTH_URL="http://localhost:3001"

# Seed admin user, created by `npm run db:seed`.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="password123"
