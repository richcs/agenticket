# Environment for Playwright / E2E tests.
# Loaded by `npm run start:e2e` (the server under test) and by the Playwright
# globalSetup (to run migrations). Uses the isolated `postgres-test` container
# (docker-compose.yml, port 5433) and dedicated ports so it never touches the
# dev server (3001) or dev DB (5432/helpdesk).
#
# NODE_ENV=test keeps Better Auth's rate limiting off (it's production-only),
# so credential sign-in during tests isn't throttled.
#
# These values are non-secret, test-only defaults — safe to commit.

PORT=3101
CLIENT_ORIGIN=http://localhost:5273
NODE_ENV=test

DATABASE_URL="postgresql://postgres:postgres@localhost:5433/helpdesk_test?schema=public"

# Better Auth — test-only secret (32+ chars).
BETTER_AUTH_SECRET="test-only-secret-not-used-in-production-00"
BETTER_AUTH_URL="http://localhost:3101"

# Seed admin user, created by `npm run db:seed`.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="password123"
